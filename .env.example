# Server: copy to apps/server/.env
#
# Supabase: Dashboard → Connect → Session pooler → copy URI into DATABASE_URL below.
# Direct db.* host can be IPv6-only; use the pooler string for local dev if you see ENOTFOUND.

DATABASE_URL=

# Optional: CORS_ORIGIN=http://localhost:5173

# Production / Vercel file uploads (public Supabase Storage bucket — see README)
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_STORAGE_BUCKET=feedback-uploads
